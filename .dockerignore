# Keep the build context tiny — only what the Worker image actually needs.

# Everything off by default; whitelist what we want in.
**

!package.json
!bun.lock
!tsconfig.base.json

!packages/shared/**
!packages/worker/**

# `bun install --frozen-lockfile` validates against the whole workspace set
# recorded in bun.lock, so the sibling manifests must be in context too (just
# the package.json — their source never enters the image).
!packages/backend/package.json
!packages/frontend/package.json
!packages/migrate/package.json

# Re-exclude things we never want even inside whitelisted dirs.
**/node_modules
**/.bun
**/dist
**/build
**/.DS_Store
**/.git
**/.codegraph
**/.claude
**/*.log
**/*.tsbuildinfo
**/.env
**/.env.*

# Test artifacts that don't belong in the image.
**/test-assets/*.mp4
**/__tests__
**/*.test.ts
