# Copy to `.env` next to docker-compose.yml on the NAS. Never commit a real .env.

# Image reference — what you tagged + pushed from your dev machine.
PWE_WORKER_IMAGE=ghcr.io/REPLACE_ME/pwe-worker:0.1.0

# Shared secret with the Pi backend. Generate once:
#   openssl rand -hex 32
# Then add the SAME value to ~/.config/pi-wallpaper-engine/auth.env on the Pi.
PWE_WORKER_API_KEY=REPLACE_ME

# Pi LAN URL. Prefer the LAN IP over a public Tunnel hostname.
PWE_BACKEND_URL=http://pi.local:8080

# How this Worker identifies itself in claim requests (free-form).
PWE_WORKER_NAME=nas-01

# Host path of the shared media. Must be the same physical files the Pi sees.
PWE_MEDIA_HOST=/mnt/nas/media
