{
  "name": "pi-wallpaper-engine",
  "private": true,
  "version": "0.1.0",
  "description": "Wallpaper Engine video wallpaper player for Raspberry Pi 4B",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bash dev.sh",
    "dev:backend": "bun run --filter @pwe/backend dev",
    "dev:frontend": "bun run --filter @pwe/frontend dev",
    "build": "bun run --filter @pwe/frontend build",
    "check": "bun run --filter @pwe/backend check",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "service:start": "systemctl --user start pi-wallpaper-engine",
    "service:stop": "systemctl --user stop pi-wallpaper-engine",
    "service:restart": "bun scripts/restart-prod.ts",
    "service:status": "systemctl --user status pi-wallpaper-engine",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun test; codegraph index",
    "post-merge": "codegraph index",
    "post-checkout": "codegraph index"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "^1.1.0",
    "@types/bun": "latest",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
